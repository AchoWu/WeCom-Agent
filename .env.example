# 企业微信智能机器人凭据
# 复制此文件为 .env 并填入你的真实值

# 机器人 Bot ID（在企业微信管理后台创建智能机器人后获取）
WECOM_BOT_ID=your_bot_id_here

# 机器人 Secret
WECOM_BOT_SECRET=your_bot_secret_here

# 群聊 Webhook URL（可选，不配置不影响核心功能）
# 仅 send/send_md/send_image/send_file 命令需要，ws_send 不依赖此项
# 获取方式：企业微信群聊 → 右上角「...」→ 添加群机器人 → 复制 Webhook 地址
# WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here
